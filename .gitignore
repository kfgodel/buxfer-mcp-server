# Credentials — never commit. Each module has its own .env (e.g.
# kotlin/.env, api-recordings/.env); the pattern catches all of them.
kotlin/.env
**/.env

# Kotlin / Gradle
kotlin/.gradle/
kotlin/build/

# TypeScript / Node
typescript/node_modules/
typescript/dist/

# Python
python/__pycache__/
python/.venv/
python/*.egg-info/

# macOS
.DS_Store

# IDE files
.idea/
*.iml
logs/
