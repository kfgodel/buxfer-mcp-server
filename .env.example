# Copy this file to .env and fill in your Buxfer credentials.
# .env is gitignored — never commit real credentials.
#
# Used by:
#   api-recordings/run-capture.sh  (capturing real API responses)
#   kotlin/   gradle run           (running the MCP server locally)
#   typescript/  npm start         (once implemented)
#   python/      python -m ...     (once implemented)

BUXFER_EMAIL=
BUXFER_PASSWORD=

# Optional. Where the Kotlin server writes its rolling log files.
# Default: ./logs (relative to the process working directory).
# BUXFER_LOG_DIR=./logs

# Optional. Logback root level. Lowering to DEBUG enables argument-value
# logging in tools and HTTP request/response logging in BuxferClient.
# Always-redacted values (password / token / statement / email) stay
# redacted at every level. Default: INFO.
# BUXFER_LOG_LEVEL=INFO

# Optional. Buxfer REST API base URL. Useful for pointing the server at a
# staging environment or a local WireMock stub during development.
# Default: https://www.buxfer.com/api
# BUXFER_API_BASE_URL=https://www.buxfer.com/api
