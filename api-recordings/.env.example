# Copy this file to api-recordings/.env and fill in your Buxfer credentials.
# .env is gitignored — never commit real credentials.
#
# Used by run-capture.sh to authenticate against the live Buxfer API while
# capturing fresh fixtures. Each module keeps its own .env so the capture
# tool, the Kotlin server, and any future language implementations stay
# standalone — even though they happen to need the same two values.

BUXFER_EMAIL=
BUXFER_PASSWORD=
