# Copy this file to kotlin/.env and fill in your Buxfer credentials.
# .env is gitignored — never commit real credentials.
#
# Loaded by Env.load on server startup. The default path is ./.env relative
# to the JVM's working directory; pass --env-file=<absolute-path> to override.

BUXFER_EMAIL=
BUXFER_PASSWORD=

# Optional. Where the rolling log appender writes. Resolved relative to the
# JVM's working directory at launch — set to an absolute path here if you
# want logs in a stable location regardless of how the server was started.
# Default: ./logs
# BUXFER_LOG_DIR=./logs

# Optional. Logback root level. Lowering to DEBUG enables argument-value
# logging in tools and HTTP request/response logging in BuxferClient.
# Always-redacted values (password / token / statement / email) stay
# redacted at every level. Default: INFO.
# BUXFER_LOG_LEVEL=INFO

# Optional. Buxfer REST API base URL. Useful for pointing the server at a
# staging environment or a local WireMock stub during development.
# Default: https://www.buxfer.com/api
# BUXFER_API_BASE_URL=https://www.buxfer.com/api
